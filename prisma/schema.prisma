generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth) ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users ───────────────────────────────────────────────────────

enum UserType {
  HUMAN
  AGENT
}

enum ReputationLevel {
  NOVICE
  TRUSTED
  EXPERT
  MASTER
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  userType      UserType        @default(HUMAN)
  bio           String?
  skillTags     String[]        @default([])
  walletAddress String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  apiKeys       ApiKey[]

  // Marketplace
  tasksCreated      Task[]          @relation("TaskCreator")
  bids              TaskBid[]
  deliveries        TaskDelivery[]
  resourcesCreated  Resource[]      @relation("ResourceCreator")
  rentals           ResourceRental[] @relation("Renter")

  // Financial
  escrowsAsPayer    Escrow[]        @relation("EscrowPayer")
  escrowsAsPayee    Escrow[]        @relation("EscrowPayee")
  transactions      Transaction[]

  // Reputation
  reputation        Reputation?
  reviewsGiven      Review[]        @relation("ReviewAuthor")
  reviewsReceived   Review[]        @relation("ReviewTarget")

  // Disputes
  disputesInitiated Dispute[]       @relation("DisputeInitiator")
  disputeEvidences  DisputeEvidence[]
}

model ApiKey {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  userId    String
  lastUsed  DateTime?
  createdAt DateTime @default(now())
  expiresAt DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Tasks ───────────────────────────────────────────────────────

enum TaskStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  PENDING_VERIFICATION
  COMPLETED
  DISPUTED
  CANCELLED
}

model Task {
  id              String     @id @default(cuid())
  title           String
  description     String
  category        String
  skillTags       String[]   @default([])
  budgetMin       Float
  budgetMax       Float
  currency        String     @default("USDC")
  status          TaskStatus @default(DRAFT)
  verificationLevel Int      @default(2) // 1=auto, 2=requester, 3=arbitration
  externalSource  String?    // e.g. "reddit:r/forhire"
  externalUrl     String?
  deadline        DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  creatorId       String
  creator         User       @relation("TaskCreator", fields: [creatorId], references: [id])
  assigneeId      String?

  bids            TaskBid[]
  deliveries      TaskDelivery[]
  escrow          Escrow?
  dispute         Dispute?
  reviews         Review[]

  @@index([status])
  @@index([category])
  @@index([creatorId])
  @@index([externalUrl])
}

model TaskBid {
  id          String   @id @default(cuid())
  amount      Float
  proposal    String
  estimatedDays Int?
  accepted    Boolean  @default(false)
  createdAt   DateTime @default(now())

  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  bidderId    String
  bidder      User     @relation(fields: [bidderId], references: [id])

  @@unique([taskId, bidderId])
  @@index([taskId])
}

model TaskDelivery {
  id          String   @id @default(cuid())
  content     String
  fileUrls    String[] @default([])
  status      String   @default("SUBMITTED") // SUBMITTED, ACCEPTED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  submitterId String
  submitter   User     @relation(fields: [submitterId], references: [id])

  @@index([taskId])
}

// ─── Resources ───────────────────────────────────────────────────

enum ResourceStatus {
  AVAILABLE
  OCCUPIED
  DELISTED
}

enum PricingModel {
  PER_CALL
  PER_UNIT
  PER_TIME
  BUYOUT
}

model Resource {
  id            String         @id @default(cuid())
  title         String
  description   String
  category      String
  tags          String[]       @default([])
  pricingModel  PricingModel
  price         Float
  currency      String         @default("USDC")
  status        ResourceStatus @default(AVAILABLE)
  accessInfo    String?        // Encrypted access credentials / endpoint
  totalUnits    Int?           // For per_unit: total available
  usedUnits     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  creatorId     String
  creator       User           @relation("ResourceCreator", fields: [creatorId], references: [id])

  rentals       ResourceRental[]

  @@index([status])
  @@index([category])
  @@index([creatorId])
}

model ResourceRental {
  id          String   @id @default(cuid())
  unitsUsed   Int      @default(0)
  totalCost   Float    @default(0)
  status      String   @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  startsAt    DateTime @default(now())
  endsAt      DateTime?
  createdAt   DateTime @default(now())

  resourceId  String
  resource    Resource @relation(fields: [resourceId], references: [id])
  renterId    String
  renter      User     @relation("Renter", fields: [renterId], references: [id])

  escrow      Escrow?

  @@index([resourceId])
  @@index([renterId])
}

// ─── Payments ────────────────────────────────────────────────────

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
  FROZEN
}

model Escrow {
  id          String       @id @default(cuid())
  amount      Float
  platformFee Float        @default(0) // 5% commission
  status      EscrowStatus @default(HELD)
  txHash      String?      // On-chain transaction hash
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  payerId     String
  payer       User         @relation("EscrowPayer", fields: [payerId], references: [id])
  payeeId     String?
  payee       User?        @relation("EscrowPayee", fields: [payeeId], references: [id])

  taskId      String?      @unique
  task        Task?        @relation(fields: [taskId], references: [id])
  rentalId    String?      @unique
  rental      ResourceRental? @relation(fields: [rentalId], references: [id])
}

model Transaction {
  id          String   @id @default(cuid())
  amount      Float
  type        String   // ESCROW_LOCK, ESCROW_RELEASE, ESCROW_REFUND, RESOURCE_PAYMENT
  txHash      String?
  fromAddress String?
  toAddress   String?
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ─── Reputation ──────────────────────────────────────────────────

model Reputation {
  id              String          @id @default(cuid())
  completionRate  Float           @default(0)
  averageRating   Float           @default(0)
  totalEarnings   Float           @default(0)
  totalSpent      Float           @default(0)
  disputeRate     Float           @default(0)
  tasksCompleted  Int             @default(0)
  tasksCreated    Int             @default(0)
  level           ReputationLevel @default(NOVICE)
  updatedAt       DateTime        @updatedAt

  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  authorId  String
  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  targetId  String
  target    User     @relation("ReviewTarget", fields: [targetId], references: [id])
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id])

  @@unique([authorId, targetId, taskId])
}

// ─── Disputes ────────────────────────────────────────────────────

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
}

enum DisputeResolution {
  FULL_RELEASE
  PARTIAL_REFUND
  FULL_REFUND
}

model Dispute {
  id          String             @id @default(cuid())
  reason      String
  status      DisputeStatus      @default(OPEN)
  resolution  DisputeResolution?
  aiVerdict   String?            // AI arbitrator's reasoning
  refundPercent Float?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  taskId      String             @unique
  task        Task               @relation(fields: [taskId], references: [id])
  initiatorId String
  initiator   User               @relation("DisputeInitiator", fields: [initiatorId], references: [id])

  evidences   DisputeEvidence[]
}

model DisputeEvidence {
  id          String   @id @default(cuid())
  content     String
  fileUrls    String[] @default([])
  createdAt   DateTime @default(now())

  disputeId   String
  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  submitterId String
  submitter   User     @relation(fields: [submitterId], references: [id])

  @@index([disputeId])
}
