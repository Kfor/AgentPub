generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ────────────────────────────────────────

enum UserType {
  HUMAN
  AGENT
}

enum ReputationLevel {
  NOVICE
  TRUSTED
  EXPERT
  MASTER
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  passwordHash  String?
  image         String?
  userType      UserType  @default(HUMAN)
  walletAddress String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Auth relations
  accounts      Account[]
  sessions      Session[]
  apiKeys       ApiKey[]

  // Marketplace relations
  tasksCreated      Task[]         @relation("TaskCreator")
  bids              Bid[]
  deliveries        Delivery[]
  resourcesOwned    Resource[]     @relation("ResourceOwner")
  resourceRentals   ResourceRental[]

  // Payment relations
  escrowsAsPayer    Escrow[]       @relation("EscrowPayer")
  escrowsAsPayee    Escrow[]       @relation("EscrowPayee")

  // Reputation
  reputation        Reputation?
  reviewsGiven      Review[]       @relation("ReviewAuthor")
  reviewsReceived   Review[]       @relation("ReviewTarget")

  // Disputes
  disputesRaised    Dispute[]      @relation("DisputeRaiser")

  // Notifications
  notifications     Notification[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model ApiKey {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  userId    String
  createdAt DateTime @default(now())
  lastUsed  DateTime?
  expiresAt DateTime?
  revoked   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ─── Tasks ───────────────────────────────────────────────

enum TaskStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  PENDING_VERIFICATION
  COMPLETED
  DISPUTED
  CANCELLED
}

enum TaskSource {
  INTERNAL
  REDDIT
  GITHUB
  FIVERR
  FREELANCER
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String
  budget      Float
  currency    String     @default("USDC")
  status      TaskStatus @default(DRAFT)
  source      TaskSource @default(INTERNAL)
  sourceUrl   String?
  sourceId    String?
  tags        String[]   @default([])
  skills      String[]   @default([])
  deadline    DateTime?
  creatorId   String
  assigneeId  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  creator     User       @relation("TaskCreator", fields: [creatorId], references: [id])
  bids        Bid[]
  deliveries  Delivery[]
  escrow      Escrow?
  disputes    Dispute[]
  reviews     Review[]

  @@index([status])
  @@index([creatorId])
  @@map("tasks")
}

// ─── Bids ────────────────────────────────────────────────

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model Bid {
  id          String    @id @default(cuid())
  amount      Float
  proposal    String
  estimatedDays Int?
  status      BidStatus @default(PENDING)
  taskId      String
  bidderId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  bidder User @relation(fields: [bidderId], references: [id])

  @@unique([taskId, bidderId])
  @@map("bids")
}

// ─── Deliveries ──────────────────────────────────────────

enum DeliveryStatus {
  SUBMITTED
  ACCEPTED
  REJECTED
  REVISION_REQUESTED
}

model Delivery {
  id          String         @id @default(cuid())
  content     String
  attachments String[]       @default([])
  status      DeliveryStatus @default(SUBMITTED)
  taskId      String
  submitterId String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  submitter User @relation(fields: [submitterId], references: [id])

  @@map("deliveries")
}

// ─── Resources ───────────────────────────────────────────

enum ResourceType {
  API_CREDITS
  DATASET
  COMPUTE
  TOOL_ACCESS
  CONSULTING
  OTHER
}

enum PricingModel {
  PER_USE
  PER_UNIT
  TIME_BASED
  BUYOUT
}

enum ResourceStatus {
  AVAILABLE
  OCCUPIED
  DELISTED
}

model Resource {
  id           String         @id @default(cuid())
  title        String
  description  String
  type         ResourceType
  pricingModel PricingModel
  price        Float
  currency     String         @default("USDC")
  status       ResourceStatus @default(AVAILABLE)
  ownerId      String
  metadata     Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  owner   User             @relation("ResourceOwner", fields: [ownerId], references: [id])
  rentals ResourceRental[]

  @@index([status])
  @@index([type])
  @@map("resources")
}

model ResourceRental {
  id         String   @id @default(cuid())
  resourceId String
  renterId   String
  startedAt  DateTime @default(now())
  expiresAt  DateTime?
  active     Boolean  @default(true)
  amountPaid Float
  createdAt  DateTime @default(now())

  resource Resource @relation(fields: [resourceId], references: [id])
  renter   User     @relation(fields: [renterId], references: [id])

  @@map("resource_rentals")
}

// ─── Escrow & Payments ───────────────────────────────────

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
  FROZEN
}

model Escrow {
  id              String       @id @default(cuid())
  amount          Float
  platformFee     Float        @default(0)
  currency        String       @default("USDC")
  status          EscrowStatus @default(HELD)
  taskId          String       @unique
  payerId         String
  payeeId         String?
  transactionHash String?
  releaseHash     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  task  Task @relation(fields: [taskId], references: [id])
  payer User @relation("EscrowPayer", fields: [payerId], references: [id])
  payee User? @relation("EscrowPayee", fields: [payeeId], references: [id])

  @@map("escrows")
}

// ─── Reputation ──────────────────────────────────────────

model Reputation {
  id              String          @id @default(cuid())
  userId          String          @unique
  completionRate  Float           @default(0)
  averageRating   Float           @default(0)
  totalEarnings   Float           @default(0)
  totalSpending   Float           @default(0)
  disputeRate     Float           @default(0)
  tasksCompleted  Int             @default(0)
  tasksCreated    Int             @default(0)
  level           ReputationLevel @default(NOVICE)
  updatedAt       DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reputations")
}

model Review {
  id         String   @id @default(cuid())
  rating     Int
  comment    String?
  taskId     String
  authorId   String
  targetId   String
  createdAt  DateTime @default(now())

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation("ReviewAuthor", fields: [authorId], references: [id])
  target User @relation("ReviewTarget", fields: [targetId], references: [id])

  @@unique([taskId, authorId])
  @@map("reviews")
}

// ─── Disputes ────────────────────────────────────────────

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
}

enum DisputeResolution {
  FULL_RELEASE
  PARTIAL_REFUND
  FULL_REFUND
}

model Dispute {
  id           String             @id @default(cuid())
  reason       String
  status       DisputeStatus      @default(OPEN)
  resolution   DisputeResolution?
  aiAnalysis   String?
  taskId       String
  raisedById   String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  task     Task              @relation(fields: [taskId], references: [id])
  raisedBy User              @relation("DisputeRaiser", fields: [raisedById], references: [id])
  evidence DisputeEvidence[]

  @@map("disputes")
}

model DisputeEvidence {
  id          String   @id @default(cuid())
  content     String
  attachments String[] @default([])
  disputeId   String
  submitterId String
  createdAt   DateTime @default(now())

  dispute Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@map("dispute_evidence")
}

// ─── Notifications ───────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  userId    String
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}
