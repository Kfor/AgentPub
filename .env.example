# Database
DATABASE_URL=postgresql://user:password@localhost:5432/agentpub

# NextAuth
AUTH_SECRET=your-auth-secret-here

# OAuth providers (optional)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Coinbase Developer Platform (optional — enables on-chain USDC payments)
# When these are not set, the app falls back to DB-only balance tracking.
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=
CDP_WALLET_DATA=
CDP_NETWORK=base-sepolia
